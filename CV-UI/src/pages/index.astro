---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Extracción y Edición de CV">
  <div class="max-w-4xl mx-auto">
    <!-- Encabezado de la página -->
    <div class="space-y-2 text-center sm:text-left mb-8">
      <h1 class="font-display text-4xl font-bold tracking-tight text-text-marino">
        Extracción y Carga de Perfiles Docentes
      </h1>
      <p class="font-sans text-sm text-text-marino/70 max-w-2xl leading-relaxed">
        Sube el currículum de un profesor en formato PDF (generado por el Sistema Institucional de Curriculum Vitae). El extractor procesará el archivo para autocompletar el perfil, permitiéndote revisarlo y editarlo antes de publicarlo en la web principal de EduVitae.
      </p>
    </div>

    <!-- ESTADO 1: DRAG & DROP -->
    <div id="upload-container" class="bg-white border-2 border-dashed border-borde-gris rounded-sm p-12 text-center hover:border-acento-verde transition-colors duration-200 cursor-pointer">
      <input type="file" id="pdf-input" accept=".pdf" class="hidden" />
      <div class="space-y-4">
        <div class="text-4xl text-acento-verde">📁</div>
        <div class="space-y-2">
          <p class="font-section text-lg font-semibold">Arrastra y suelta el PDF aquí</p>
          <p class="text-xs text-text-marino/60 font-mono">o haz clic para buscar el archivo en tu equipo</p>
        </div>
        <p class="text-[10px] text-text-marino/50 font-mono max-w-md mx-auto leading-relaxed">
          * El PDF debe seguir el formato oficial de la Universidad de Colima (CV2026).
        </p>
      </div>
    </div>

    <!-- ESTADO 2: CARGANDO / PROCESANDO -->
    <div id="loading-container" class="hidden bg-white border border-borde-gris rounded-sm p-12 text-center space-y-6">
      <div class="relative w-16 h-16 mx-auto flex items-center justify-center">
        <!-- Spinner elegante clásico -->
        <div class="absolute inset-0 border-2 border-borde-gris rounded-full"></div>
        <div class="absolute inset-0 border-2 border-t-acento-verde rounded-full animate-spin"></div>
        <span class="font-mono text-[10px] text-acento-verde font-bold">PDF</span>
      </div>
      
      <div class="space-y-2">
        <h3 class="font-section text-base font-bold text-text-marino">Procesando documento...</h3>
        <p class="font-mono text-xs text-text-marino/60" id="loading-status">Ejecutando cv_scraper.py en el servidor...</p>
      </div>

      <div class="w-full bg-bg-piedra h-1.5 max-w-xs mx-auto rounded-full overflow-hidden">
        <div class="bg-acento-verde h-full animate-[loading-bar_2s_infinite_linear]" style="width: 50%;"></div>
      </div>
    </div>

    <!-- ESTADO 3: ERROR -->
    <div id="error-container" class="hidden bg-white border border-acento-verde/40 border-double-academic rounded-sm p-6 text-center space-y-4">
      <div class="text-2xl text-acento-verde">⚠️ Error de Extracción</div>
      <p class="text-xs font-mono text-acento-verde" id="error-message"></p>
      <button id="btn-error-retry" class="px-4 py-2 border border-acento-verde text-acento-verde text-xs font-mono rounded-sm hover:bg-acento-verde hover:text-white transition-all cursor-pointer">
        Intentar de nuevo
      </button>
    </div>

    <!-- ESTADO 4: EDITOR INTERACTIVO -->
    <div id="editor-container" class="hidden space-y-6">
      <!-- Tarjeta de Resumen -->
      <div class="bg-white border border-borde-gris rounded-sm p-4 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div>
          <span class="text-[9px] font-mono uppercase text-text-marino/50 tracking-widest block">Docente Detectado</span>
          <h2 id="editor-summary-name" class="font-display text-2xl font-bold text-text-marino"></h2>
          <p id="editor-summary-title" class="text-xs text-text-marino/70 font-sans"></p>
        </div>
        <div class="flex gap-2 w-full sm:w-auto">
          <button id="btn-cancel" class="flex-1 sm:flex-none px-4 py-2 border border-borde-gris text-text-marino/70 text-xs font-mono rounded-sm hover:bg-bg-piedra transition-all cursor-pointer">
            Descartar
          </button>
          <button id="btn-save" class="flex-1 sm:flex-none px-6 py-2 bg-acento-verde text-white text-xs font-mono rounded-sm hover:bg-opacity-90 transition-all font-bold cursor-pointer">
            Confirmar Datos
          </button>
        </div>
      </div>

      <!-- Pestañas (Tabs) del Editor -->
      <div class="bg-white border border-borde-gris rounded-sm flex flex-col min-h-[500px]">
        <!-- Encabezado de Pestañas -->
        <div class="flex flex-wrap border-b border-borde-gris font-section text-[10px] sm:text-xs uppercase tracking-wider font-bold bg-bg-piedra/30">
          <button class="editor-tab-btn px-4 py-3 hover:text-acento-verde border-b-2 border-acento-verde text-acento-verde cursor-pointer transition-all duration-150" data-tab="personales">
            Datos Generales
          </button>
          <button class="editor-tab-btn px-4 py-3 hover:text-acento-verde border-b-2 border-transparent text-text-marino/70 cursor-pointer transition-all duration-150" data-tab="academicos">
            Estudios y Certs.
          </button>
          <button class="editor-tab-btn px-4 py-3 hover:text-acento-verde border-b-2 border-transparent text-text-marino/70 cursor-pointer transition-all duration-150" data-tab="produccion">
            Producción
          </button>
          <button class="editor-tab-btn px-4 py-3 hover:text-acento-verde border-b-2 border-transparent text-text-marino/70 cursor-pointer transition-all duration-150" data-tab="didactico">
            Materiales
          </button>
          <button class="editor-tab-btn px-4 py-3 hover:text-acento-verde border-b-2 border-transparent text-text-marino/70 cursor-pointer transition-all duration-150" data-tab="docencia">
            Docencia y Tesis
          </button>
        </div>

        <!-- Contenedor del Panel Activo -->
        <div class="p-6 flex-grow" id="editor-panel-content">
          <!-- RENDERIZADO DINÁMICAMENTE POR JS -->
        </div>
      </div>
    </div>

    <!-- ESTADO 5: EXPORTACIÓN EXITOSA -->
    <div id="success-container" class="hidden bg-white border-double-academic p-12 text-center space-y-6">
      <div class="text-4xl text-green-700">✓</div>
      <div class="space-y-2">
        <h2 class="font-display text-3xl font-bold text-text-marino">¡Currículum Exportado con Éxito!</h2>
        <p class="font-sans text-sm text-text-marino/70 max-w-md mx-auto">
          Los datos del docente han sido formateados y guardados en el proyecto principal de **EduVitae**. El perfil ya está disponible para visualización.
        </p>
      </div>
      
      <div class="pt-4 flex flex-col sm:flex-row justify-center gap-3">
        <button id="btn-success-new" class="px-6 py-2.5 bg-acento-verde text-white text-xs font-mono rounded-sm hover:bg-opacity-90 transition-all font-bold cursor-pointer">
          Procesar Otro PDF
        </button>
        <a href="http://localhost:6767/docentes" target="_blank" rel="noopener noreferrer" class="px-6 py-2.5 border border-borde-gris text-text-marino/70 text-xs font-mono rounded-sm hover:bg-bg-piedra transition-all flex items-center justify-center">
          Ver Claustro en EduVitae
        </a>
      </div>
    </div>
  </div>
</Layout>

<style>
  @keyframes loading-bar {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(200%); }
  }
</style>

<!-- LÓGICA DE CLIENTE (VINCULACIÓN E INTERACTIVIDAD) -->
<script>
  let currentCVData = null;
  let activeTab = 'personales';

  // --- REFERENCIAS DOM ---
  const uploadContainer = document.getElementById('upload-container');
  const loadingContainer = document.getElementById('loading-container');
  const errorContainer = document.getElementById('error-container');
  const editorContainer = document.getElementById('editor-container');
  const successContainer = document.getElementById('success-container');
  
  const pdfInput = document.getElementById('pdf-input');
  const loadingStatus = document.getElementById('loading-status');
  const errorMessage = document.getElementById('error-message');
  
  const editorSummaryName = document.getElementById('editor-summary-name');
  const editorSummaryTitle = document.getElementById('editor-summary-title');
  const editorPanelContent = document.getElementById('editor-panel-content');
  
  const btnCancel = document.getElementById('btn-cancel');
  const btnSave = document.getElementById('btn-save');
  const btnErrorRetry = document.getElementById('btn-error-retry');
  const btnSuccessNew = document.getElementById('btn-success-new');

  // --- EVENTOS DRAG & DROP ---
  if (uploadContainer) {
    uploadContainer.addEventListener('click', () => pdfInput && pdfInput.click());
    
    uploadContainer.addEventListener('dragover', (e) => {
      e.preventDefault();
      uploadContainer.classList.add('border-acento-verde');
    });
    
    uploadContainer.addEventListener('dragleave', () => {
      uploadContainer.classList.remove('border-acento-verde');
    });
    
    uploadContainer.addEventListener('drop', (e) => {
      e.preventDefault();
      uploadContainer.classList.remove('border-acento-verde');
      const files = e.dataTransfer?.files;
      if (files && files.length > 0) {
        handleFile(files[0]);
      }
    });
  }

  if (pdfInput) {
    pdfInput.addEventListener('change', (e) => {
      const target = e.target as HTMLInputElement;
      const files = target.files;
      if (files && files.length > 0) {
        handleFile(files[0]);
      }
    });
  }

  // --- GESTIÓN DE ARCHIVOS Y LLAMADOS A API ---
  async function handleFile(file: File) {
    if (file.type !== 'application/pdf') {
      alert('Por favor, selecciona un archivo en formato PDF.');
      return;
    }

    // Cambiar a pantalla de carga
    showState('loading');
    if (loadingStatus) loadingStatus.textContent = 'Enviando PDF al extractor...';

    try {
      const formData = new FormData();
      formData.append('pdf', file);

      if (loadingStatus) loadingStatus.textContent = 'Ejecutando cv_scraper.py (Extrayendo información del PDF)...';
      
      const res = await fetch('http://localhost:6769/api/extract', {
        method: 'POST',
        body: formData
      });

      if (!res.ok) {
        const errJson = await res.json();
        throw new Error(errJson.error || 'Ocurrió un error al procesar el currículum.');
      }

      currentCVData = await res.json();
      
      // Mostrar editor
      if (editorSummaryName) editorSummaryName.textContent = currentCVData.professorData.fullName || 'Nombre No Detectado';
      if (editorSummaryTitle) {
        editorSummaryTitle.textContent = `${currentCVData.professorData.laborData.currentAppointment || 'Docente'} — ${currentCVData.professorData.laborData.academicUnit || 'Facultad'}`;
      }
      
      activeTab = 'personales';
      updateTabButtons();
      renderActiveTab();
      showState('editor');
    } catch (err: any) {
      console.error(err);
      if (errorMessage) errorMessage.textContent = err.message || 'Error al conectar con el servidor.';
      showState('error');
    }
  }

  // --- BOTÓN EXPORTAR / LISTO ---
  if (btnSave) {
    btnSave.addEventListener('click', async () => {
      if (!currentCVData) return;

      showState('loading');
      if (loadingStatus) loadingStatus.textContent = 'Guardando cambios y exportando a EduVitae...';

      try {
        const res = await fetch('http://localhost:6769/api/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(currentCVData)
        });

        if (!res.ok) {
          const errJson = await res.json();
          throw new Error(errJson.error || 'Ocurrió un error al exportar la información.');
        }

        showState('success');
      } catch (err: any) {
        console.error(err);
        alert(`Error al guardar: ${err.message}`);
        showState('editor');
      }
    });
  }

  // --- NAVEGACIÓN Y ACCIONES ---
  if (btnCancel) {
    btnCancel.addEventListener('click', () => {
      if (confirm('¿Estás seguro de que deseas descartar este currículum? Se perderán todos los cambios no guardados.')) {
        currentCVData = null;
        if (pdfInput) pdfInput.value = '';
        showState('upload');
      }
    });
  }

  if (btnErrorRetry) {
    btnErrorRetry.addEventListener('click', () => {
      currentCVData = null;
      if (pdfInput) pdfInput.value = '';
      showState('upload');
    });
  }

  if (btnSuccessNew) {
    btnSuccessNew.addEventListener('click', () => {
      currentCVData = null;
      if (pdfInput) pdfInput.value = '';
      showState('upload');
    });
  }

  // Controladores de pestañas
  document.querySelectorAll('.editor-tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tab = btn.getAttribute('data-tab');
      if (tab) {
        activeTab = tab;
        updateTabButtons();
        renderActiveTab();
      }
    });
  });

  function updateTabButtons() {
    document.querySelectorAll('.editor-tab-btn').forEach((btn) => {
      const tab = btn.getAttribute('data-tab');
      if (tab === activeTab) {
        btn.classList.add('text-acento-verde', 'border-b-acento-verde');
        btn.classList.remove('border-transparent', 'text-text-marino/70');
      } else {
        btn.classList.remove('text-acento-verde', 'border-b-acento-verde');
        btn.classList.add('border-transparent', 'text-text-marino/70');
      }
    });
  }

  // --- UTILIDADES DE RENDERIZACIÓN DE PESTAÑAS ---
  function showState(state: 'upload' | 'loading' | 'error' | 'editor' | 'success') {
    uploadContainer?.classList.toggle('hidden', state !== 'upload');
    loadingContainer?.classList.toggle('hidden', state !== 'loading');
    errorContainer?.classList.toggle('hidden', state !== 'error');
    editorContainer?.classList.toggle('hidden', state !== 'editor');
    successContainer?.classList.toggle('hidden', state !== 'success');
  }

  function renderActiveTab() {
    if (!editorPanelContent || !currentCVData) return;

    let html = '';

    if (activeTab === 'personales') {
      const p = currentCVData.professorData;
      html = `
        <div class="space-y-6 max-h-[600px] overflow-y-auto scrollbar-academic pr-2">
          <!-- Bloque Datos Personales -->
          <div>
            <h4 class="font-section text-xs uppercase tracking-widest font-semibold text-acento-verde mb-3 flex items-center">
              <span class="text-acento-verde mr-2">§</span> Datos Personales de Contacto
            </h4>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="font-mono text-[9px] uppercase tracking-wider font-bold text-text-marino/75 block mb-1">Nombre Completo</label>
                <input type="text" value="${p.fullName || ''}" oninput="window.updateField('professorData.fullName', this.value)" class="w-full text-xs font-sans bg-white border border-borde-gris rounded-sm p-2 text-text-marino focus:border-acento-verde outline-none" />
              </div>
              <div>
                <label class="font-mono text-[9px] uppercase tracking-wider font-bold text-text-marino/75 block mb-1">Idioma Materno</label>
                <input type="text" value="${p.contactInfo?.nativeLanguage || ''}" oninput="window.updateField('professorData.contactInfo.nativeLanguage', this.value)" class="w-full text-xs font-sans bg-white border border-borde-gris rounded-sm p-2 text-text-marino focus:border-acento-verde outline-none" />
              </div>
              <div>
                <label class="font-mono text-[9px] uppercase tracking-wider font-bold text-text-marino/75 block mb-1">Correo Institucional</label>
                <input type="email" value="${p.contactInfo?.institutionalEmail || ''}" oninput="window.updateField('professorData.contactInfo.institutionalEmail', this.value)" class="w-full text-xs font-sans bg-white border border-borde-gris rounded-sm p-2 text-text-marino focus:border-acento-verde outline-none" />
              </div>
              <div>
                <label class="font-mono text-[9px] uppercase tracking-wider font-bold text-text-marino/75 block mb-1">Correo Adicional (Opcional)</label>
                <input type="email" value="${p.contactInfo?.additionalEmail || ''}" oninput="window.updateField('professorData.contactInfo.additionalEmail', this.value)" class="w-full text-xs font-sans bg-white border border-borde-gris rounded-sm p-2 text-text-marino focus:border-acento-verde outline-none" />
              </div>
              <div>
                <label class="font-mono text-[9px] uppercase tracking-wider font-bold text-text-marino/75 block mb-1">Teléfono</label>
                <input type="text" value="${p.contactInfo?.phone || ''}" oninput="window.updateField('professorData.contactInfo.phone', this.value)" class="w-full text-xs font-sans bg-white border border-borde-gris rounded-sm p-2 text-text-marino focus:border-acento-verde outline-none" />
              </div>
              <div>
                <label class="font-mono text-[9px] uppercase tracking-wider font-bold text-text-marino/75 block mb-1">Domicilio Particular (Privado)</label>
                <input type="text" value="${p.contactInfo?.homeAddress || ''}" oninput="window.updateField('professorData.contactInfo.homeAddress', this.value)" class="w-full text-xs font-sans bg-white border border-borde-gris rounded-sm p-2 text-text-marino focus:border-acento-verde outline-none" />
              </div>
            </div>
          </div>

          <hr class="academic-divider" />

          <!-- Bloque Datos Laborales -->
          <div>
            <h4 class="font-section text-xs uppercase tracking-widest font-semibold text-acento-verde mb-3 flex items-center">
              <span class="text-acento-verde mr-2">§</span> Información Académica y Adscripción
            </h4>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="font-mono text-[9px] uppercase tracking-wider font-bold text-text-marino/75 block mb-1">Nombramiento Actual</label>
                <input type="text" value="${p.laborData?.currentAppointment || ''}" oninput="window.updateField('professorData.laborData.currentAppointment', this.value)" class="w-full text-xs font-sans bg-white border border-borde-gris rounded-sm p-2 text-text-marino focus:border-acento-verde outline-none" />
              </div>
              <div>
                <label class="font-mono text-[9px] uppercase tracking-wider font-bold text-text-marino/75 block mb-1">Unidad Académica / DES</label>
                <input type="text" value="${p.laborData?.academicUnit || ''}" oninput="window.updateField('professorData.laborData.academicUnit', this.value)" class="w-full text-xs font-sans bg-white border border-borde-gris rounded-sm p-2 text-text-marino focus:border-acento-verde outline-none" />
              </div>
              <div>
                <label class="font-mono text-[9px] uppercase tracking-wider font-bold text-text-marino/75 block mb-1">Fecha de Ingreso a la Institución</label>
                <input type="date" value="${p.laborData?.admissionDate || ''}" oninput="window.updateField('professorData.laborData.admissionDate', this.value)" class="w-full text-xs font-sans bg-white border border-borde-gris rounded-sm p-2 text-text-marino focus:border-acento-verde outline-none" />
              </div>
              <div>
                <label class="font-mono text-[9px] uppercase tracking-wider font-bold text-text-marino/75 block mb-1">Número de Empleado (Oculto en web)</label>
                <input type="number" value="${p.laborData?.employeeNumber || ''}" oninput="window.updateField('professorData.laborData.employeeNumber', this.value)" class="w-full text-xs font-sans bg-white border border-borde-gris rounded-sm p-2 text-text-marino focus:border-acento-verde outline-none" />
              </div>
              <div class="sm:col-span-2">
                <label class="font-mono text-[9px] uppercase tracking-wider font-bold text-text-marino/75 block mb-1">Dirección de Trabajo</label>
                <input type="text" value="${p.laborData?.workAddress || ''}" oninput="window.updateField('professorData.laborData.workAddress', this.value)" class="w-full text-xs font-sans bg-white border border-borde-gris rounded-sm p-2 text-text-marino focus:border-acento-verde outline-none" />
              </div>
            </div>
          </div>

          <hr class="academic-divider" />

          <!-- Bloque Cuerpo Académico -->
          <div>
            <h4 class="font-section text-xs uppercase tracking-widest font-semibold text-acento-verde mb-3 flex items-center">
              <span class="text-acento-verde mr-2">§</span> Cuerpo Académico (CA)
            </h4>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              <div>
                <label class="font-mono text-[9px] uppercase tracking-wider font-bold text-text-marino/75 block mb-1">Código del Cuerpo Académico</label>
                <input type="text" value="${p.laborData?.academicBody?.code || ''}" oninput="window.updateField('professorData.laborData.academicBody.code', this.value)" class="w-full text-xs font-sans bg-white border border-borde-gris rounded-sm p-2 text-text-marino focus:border-acento-verde outline-none" placeholder="Ej: UCOL-CA-91" />
              </div>
              <div>
                <label class="font-mono text-[9px] uppercase tracking-wider font-bold text-text-marino/75 block mb-1">Nombre del CA</label>
                <input type="text" value="${p.laborData?.academicBody?.name || ''}" oninput="window.updateField('professorData.laborData.academicBody.name', this.value)" class="w-full text-xs font-sans bg-white border border-borde-gris rounded-sm p-2 text-text-marino focus:border-acento-verde outline-none" />
              </div>
              <div>
                <label class="font-mono text-[9px] uppercase tracking-wider font-bold text-text-marino/75 block mb-1">Grado de Consolidación</label>
                <select onchange="window.updateField('professorData.laborData.academicBody.consolidationLevel', this.value)" class="w-full text-xs font-sans bg-white border border-borde-gris rounded-sm p-2 text-text-marino focus:border-acento-verde outline-none h-[34px]">
                  <option value="CAEC" ${p.laborData?.academicBody?.consolidationLevel === 'CAEC' ? 'selected' : ''}>En Consolidación (CAEC)</option>
                  <option value="CA-Consolidado" ${p.laborData?.academicBody?.consolidationLevel === 'CA-Consolidado' ? 'selected' : ''}>Consolidado (CA)</option>
                  <option value="CA-En-Formación" ${p.laborData?.academicBody?.consolidationLevel === 'CA-En-Formación' ? 'selected' : ''}>En Formación</option>
                </select>
              </div>
            </div>
          </div>
        </div>
      `;
    } 
    
    else if (activeTab === 'academicos') {
      const form = currentCVData.academicFormation;
      
      // Grados Académicos
      let degreesHtml = '';
      if (form.degrees && form.degrees.length > 0) {
        form.degrees.forEach((deg: any, idx: number) => {
          degreesHtml += `
            <div class="p-4 border border-borde-gris/60 rounded-sm bg-bg-piedra/10 mb-4 relative">
              <button onclick="window.removeArrayItem('academicFormation.degrees', ${idx})" class="absolute top-2 right-2 text-text-marino/50 hover:text-acento-verde font-mono text-xs cursor-pointer">✕ Eliminar</button>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div>
                  <label class="font-mono text-[9px] uppercase tracking-wider font-bold text-text-marino/75 block mb-1">Nivel de Estudio</label>
                  <select onchange="window.updateField('academicFormation.degrees.${idx}.level', this.value)" class="w-full text-xs font-sans bg-white border border-borde-gris rounded-sm p-2 text-text-marino focus:border-acento-verde outline-none h-[34px]">
                    <option value="Licenciatura" ${deg.level === 'Licenciatura' ? 'selected' : ''}>Licenciatura</option>
                    <option value="Maestría" ${deg.level === 'Maestría' ? 'selected' : ''}>Maestría</option>
                    <option value="Doctorado" ${deg.level === 'Doctorado' ? 'selected' : ''}>Doctorado</option>
                    <option value="Posdoctorado" ${deg.level === 'Posdoctorado' ? 'selected' : ''}>Posdoctorado</option>
                  </select>
                </div>
                <div class="sm:col-span-2">
