              <button onclick="window.addArrayItem('humanResources.teaching')" class="px-3 py-1 border border-acento-verde text-acento-verde text-[10px] font-mono rounded-sm hover:bg-acento-verde hover:text-white transition-all cursor-pointer">+ Agregar Materia</button>
            </div>
            ${coursesHtml}
          </div>

          <hr class="academic-divider" />

          <!-- Sección Tesis -->
          <div>
            <div class="flex justify-between items-center mb-3">
              <h4 class="font-section text-xs uppercase tracking-widest font-semibold text-acento-verde flex items-center">
                <span class="text-acento-verde mr-2">§</span> Dirección de Tesis y Proyectos
              </h4>
              <button onclick="window.addArrayItem('humanResources.theses')" class="px-3 py-1 border border-acento-verde text-acento-verde text-[10px] font-mono rounded-sm hover:bg-acento-verde hover:text-white transition-all cursor-pointer">+ Agregar Tesis</button>
            </div>
            ${thesesHtml}
          </div>
        </div>
      `;
    }

    editorPanelContent.innerHTML = html;
  }

  // --- VINCULACIÓN GLOBAL DE DATOS (MÉTODOS ASIGNADOS A WINDOW) ---
  (window as any).updateField = (path: string, value: string) => {
    if (!currentCVData) return;
    
    const parts = path.split('.');
    let obj = currentCVData;
    
    for (let i = 0; i < parts.length - 1; i++) {
      const part = parts[i];
      // Si la siguiente parte es un número (índice de arreglo)
      if (!isNaN(Number(parts[i + 1]))) {
        obj = obj[part];
      } else {
        if (!obj[part]) obj[part] = {};
        obj = obj[part];
      }
    }
    
    const lastKey = parts[parts.length - 1];
    
    // Conversiones de tipos básicas
    if (value === '') {
      obj[lastKey] = null;
    } else if (!isNaN(Number(value)) && lastKey !== 'phone' && lastKey !== 'professionalId' && lastKey !== 'isbn' && lastKey !== 'issn' && lastKey !== 'code' && lastKey !== 'endDate') {
      obj[lastKey] = value.includes('.') ? parseFloat(value) : parseInt(value);
    } else {
      obj[lastKey] = value;
    }
  };

  (window as any).removeArrayItem = (path: string, index: number) => {
    if (!currentCVData || !confirm('¿Estás seguro de que deseas eliminar este elemento?')) return;
    
    const parts = path.split('.');
    let obj = currentCVData;
    for (let i = 0; i < parts.length - 1; i++) {
      obj = obj[parts[i]];
    }
    
    const arr = obj[parts[parts.length - 1]];
    if (Array.isArray(arr)) {
      arr.splice(index, 1);
      renderActiveTab();
    }
  };

  (window as any).addArrayItem = (path: string, typeSpec?: string) => {
    if (!currentCVData) return;
    
    const parts = path.split('.');
    let obj = currentCVData;
    for (let i = 0; i < parts.length - 1; i++) {
      if (!obj[parts[i]]) obj[parts[i]] = {};
      obj = obj[parts[i]];
    }
    
    const key = parts[parts.length - 1];
    if (!obj[key]) obj[key] = [];
    
    const arr = obj[key];
    
    // Plantillas de items vacíos
    let newItem = {};
    if (path.endsWith('degrees')) {
      newItem = { level: 'Licenciatura', title: '', institution: '', professionalId: '', startDate: new Date().getFullYear() - 4, endDate: new Date().getFullYear(), graduationDate: 'grado' };
    } else if (path.endsWith('certifications')) {
      newItem = { title: '', institution: '', year: new Date().getFullYear(), hours: 20, profile: 'Pedagógico', scope: 'Institucional' };
    } else if (path.endsWith('scientificProduction')) {
      if (typeSpec === 'Artículo Científico') {
        newItem = { type: 'Artículo Científico', title: '', journalName: '', year: new Date().getFullYear(), impactFactor: null, doiOrUrl: '', authors: [currentCVData.professorData.fullName] };
      } else {
        newItem = { type: 'Libro', title: '', role: 'Coautor', editorial: '', year: new Date().getFullYear(), authors: [currentCVData.professorData.fullName] };
      }
    } else if (path.endsWith('educationalMaterials')) {
      newItem = { type: 'Material Didáctico', resourceType: 'Recurso digital', title: '', year: new Date().getFullYear(), accessUrl: '', description: '', authors: [currentCVData.professorData.fullName] };
    } else if (path.endsWith('teaching')) {
      newItem = { courseName: '', level: 'Licenciatura', students: 25, period: 'Ago-Ene', year: new Date().getFullYear() };
    } else if (path.endsWith('theses')) {
      newItem = { studentName: '', thesisTitle: '', endDate: new Date().getFullYear(), role: 'Asesor' };
    }

    arr.push(newItem);
    renderActiveTab();
  };
</script>
