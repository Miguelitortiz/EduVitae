---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Extractor e Integrador de Currículum Académico para EduVitae' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} — Portal de Administración Académica</title>
  </head>
  <body class="bg-bg-papel text-text-marino font-sans min-h-screen flex flex-col">
    <!-- Encabezado Académico Superior -->
    <header class="border-b border-borde-gris bg-bg-papel py-4 px-6 sm:px-12 sticky top-0 z-50 shadow-sm backdrop-blur-md bg-opacity-95">
      <div class="max-w-6xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4">
        <div class="flex items-center gap-3">
          <div class="font-mono text-xl font-bold border-r border-borde-gris pr-4 text-acento-verde">
            ■ CV-UI
          </div>
          <div class="flex flex-col">
            <span class="font-display font-semibold text-lg tracking-tight uppercase">EduVitae Extractor</span>
            <span class="font-mono text-[9px] text-text-marino/60 uppercase tracking-widest">Universidad de Colima — Módulo de Carga</span>
          </div>
        </div>
        
        
      </div>
    </header>

    <!-- Contenido Principal -->
    <main class="flex-grow py-8 px-4 sm:px-8 max-w-6xl w-full mx-auto">
      <slot />
    </main>

    <!-- Pie de Página -->
    <footer class="border-t border-borde-gris py-6 px-6 text-center bg-bg-piedra/40 text-xs font-mono text-text-marino/60 mt-12">
      <div class="max-w-6xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4">
        <div>
          <span>Sistema de Integración Curricular Académico v0.0.1</span>
        </div>
        <div class="flex gap-4">
          <a href="http://localhost:6767" target="_blank" rel="noopener noreferrer" class="link-academic">
            → Ir a la Web Principal (EduVitae)
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
