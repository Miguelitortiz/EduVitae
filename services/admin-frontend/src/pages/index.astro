              selectGrp.innerHTML = '<option value="">Seleccione un grupo...</option>';
              selectGrp.disabled = true;
            }
          }
        });
      }

      const btnCreateGrp = document.getElementById('btn-create-group-modal');
      if (btnCreateGrp) {
        btnCreateGrp.addEventListener('click', openCreateGroupModal);
      }

      const btnAddAssignment = document.getElementById('btn-add-group-assignment');
      if (btnAddAssignment) {
        btnAddAssignment.addEventListener('click', () => {
          const selectGrp = document.getElementById('select-group') as HTMLSelectElement;
          const inputSubj = document.getElementById('input-group-subject') as HTMLInputElement;
          const groupId = selectGrp ? parseInt(selectGrp.value, 10) : null;
          const subject = inputSubj ? inputSubj.value.trim() : '';

          if (!groupId) {
            alert('Por favor, selecciona un grupo para asignar.');
            return;
          }

          const matchedGroup = currentGroups.find((g: any) => g.id === groupId);
          if (matchedGroup) {
            // Evitar duplicados
            if (groupAssignments.some(a => a.class_group_id === groupId)) {
              alert('El profesor ya está asignado a este grupo.');
              return;
            }

            groupAssignments.push({
              class_group_id: groupId,
              name: matchedGroup.name,
              subject_taught: subject
            });

            if (inputSubj) inputSubj.value = '';
            renderActiveTab();
          }
        });
      }
    }
  }

  // --- VINCULACIÓN GLOBAL DE MÉTODOS A WINDOW ---
  (window as any).updateField = (path: string, value: string) => {
    if (!currentCVData) return;
    
    const parts = path.split('.');
    let obj = currentCVData;
    
    for (let i = 0; i < parts.length - 1; i++) {
      const part = parts[i];
      if (!isNaN(Number(parts[i + 1]))) {
        obj = obj[part];
      } else {
        if (!obj[part]) obj[part] = {};
        obj = obj[part];
      }
    }
    
    const lastKey = parts[parts.length - 1];
    
    if (value === '') {
      obj[lastKey] = null;
    } else if (!isNaN(Number(value)) && lastKey !== 'phone' && lastKey !== 'professionalId' && lastKey !== 'isbn' && lastKey !== 'issn' && lastKey !== 'code' && lastKey !== 'endDate') {
      obj[lastKey] = value.includes('.') ? parseFloat(value) : parseInt(value);
    } else {
      obj[lastKey] = value;
    }

    // Sincronizar adscriptionFacultyId y delegationId al modificar academicUnit
    if (path === 'professorData.laborData.academicUnit') {
      const match = referenceFaculties.find((f: any) => f.name === value);
      if (match) {
        adscriptionFacultyId = match.id;
        delegationId = match.delegation_id;
      } else {
        adscriptionFacultyId = null;
      }
    }
  };

  (window as any).removeArrayItem = (path: string, index: number) => {
    if (!currentCVData || !confirm('¿Estás seguro de que deseas eliminar este elemento?')) return;
    
    const parts = path.split('.');
    let obj = currentCVData;
    for (let i = 0; i < parts.length - 1; i++) {
      obj = obj[parts[i]];
    }
    
    const arr = obj[parts[parts.length - 1]];
    if (Array.isArray(arr)) {
      arr.splice(index, 1);
      renderActiveTab();
    }
  };

  (window as any).removeGroupAssignment = (index: number) => {
    groupAssignments.splice(index, 1);
    renderActiveTab();
  };

  (window as any).updateAdscriptionFaculty = (val: string) => {
    adscriptionFacultyId = val ? parseInt(val, 10) : null;
    
    // Sincronizar academicUnit en los datos del perfil de texto
    if (currentCVData && currentCVData.professorData) {
      if (!currentCVData.professorData.laborData) {
        currentCVData.professorData.laborData = {};
      }
      if (adscriptionFacultyId) {
        const match = referenceFaculties.find((f: any) => f.id === adscriptionFacultyId);
        if (match) {
          currentCVData.professorData.laborData.academicUnit = match.name;
        }
      } else {
        currentCVData.professorData.laborData.academicUnit = '';
      }
    }

    const selectFac = document.getElementById('select-adscription-faculty') as HTMLSelectElement;
    if (selectFac && selectFac.selectedIndex >= 0) {
      const del = selectFac.options[selectFac.selectedIndex].getAttribute('data-delegation');
      if (del) {
        delegationId = parseInt(del, 10);
        const selectDel = document.getElementById('select-delegation') as HTMLSelectElement;
        if (selectDel) selectDel.value = String(delegationId);
      }
    }
  };

  (window as any).addArrayItem = (path: string, typeSpec?: string) => {
    if (!currentCVData) return;
    
    const parts = path.split('.');
    let obj = currentCVData;
    for (let i = 0; i < parts.length - 1; i++) {
      if (!obj[parts[i]]) obj[parts[i]] = {};
      obj = obj[parts[i]];
    }
    
    const key = parts[parts.length - 1];
    if (!obj[key]) obj[key] = [];
    
    const arr = obj[key];
    
    let newItem = {};
    if (path.endsWith('degrees')) {
      newItem = { level: 'Licenciatura', title: '', institution: '', professionalId: '', startDate: new Date().getFullYear() - 4, endDate: new Date().getFullYear(), graduationDate: 'grado' };
    } else if (path.endsWith('certifications')) {
      newItem = { title: '', institution: '', year: new Date().getFullYear(), hours: 20, profile: 'Pedagógico', scope: 'Institucional' };
    } else if (path.endsWith('scientificProduction')) {
      if (typeSpec === 'Artículo Científico') {
        newItem = { type: 'Artículo Científico', title: '', journalName: '', year: new Date().getFullYear(), impactFactor: null, doiOrUrl: '', authors: [currentCVData.professorData.fullName] };
      } else {
        newItem = { type: 'Libro', title: '', role: 'Coautor', editorial: '', year: new Date().getFullYear(), authors: [currentCVData.professorData.fullName] };
      }
    } else if (path.endsWith('educationalMaterials')) {
      newItem = { type: 'Material Didáctico', resourceType: 'Recurso digital', title: '', year: new Date().getFullYear(), accessUrl: '', description: '', authors: [currentCVData.professorData.fullName] };
    } else if (path.endsWith('teaching')) {
      newItem = { courseName: '', level: 'Licenciatura', students: 25, period: 'Ago-Ene', year: new Date().getFullYear() };
    } else if (path.endsWith('theses')) {
      newItem = { studentName: '', thesisTitle: '', endDate: new Date().getFullYear(), role: 'Asesor' };
    }

    arr.push(newItem);
    renderActiveTab();
  };
</script>
