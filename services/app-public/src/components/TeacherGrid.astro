---
interface Teacher {
  slug: string;
  fullName: string;
  photoUrl?: string;
  title: string;
  department: string;
  quote: string;
  delegation_id?: number;
  faculty_id?: number;
  career_ids?: number[];
}

interface Props {
  profesores: Teacher[];
}

const { profesores = [] } = Astro.props;

// Función para obtener iniciales
function getInitials(name: string) {
  return name
    .split(' ')
    .filter(word => word.length > 2 && !['del', 'de', 'las', 'los'].includes(word.toLowerCase()))
    .slice(0, 2)
    .map(word => word[0])
    .join('')
    .toUpperCase();
}
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
  {profesores.map((prof) => {
    const initials = getInitials(prof.fullName);
    return (
      <div 
        class="teacher-card border border-borde-gris border-l-4 border-l-acento-verde p-6 bg-white rounded-sm flex flex-col sm:flex-row gap-6 hover:border-acento-verde/40 transition-colors duration-200"
        data-delegation={prof.delegation_id}
        data-faculty={prof.faculty_id || ''}
        data-careers={JSON.stringify(prof.career_ids || [])}
      >
        <!-- Foto en miniatura con marco -->
        <div class="photo-frame shrink-0">
          <div class="w-20 h-20 sm:w-24 sm:h-24 bg-bg-piedra border border-borde-gris/40 flex items-center justify-center overflow-hidden rounded-sm relative">
            {prof.photoUrl ? (
              <img
                src={prof.photoUrl}
                alt={`Fotografía de ${prof.fullName}`}
                loading="lazy"
                class="w-full h-full object-cover filter grayscale contrast-110 sepia-[20%]"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
              />
              <div class="hidden absolute inset-0 flex items-center justify-center font-display text-2xl font-bold text-text-marino/30 tracking-widest bg-bg-piedra select-none">
                {initials}
              </div>
            ) : (
              <div class="flex items-center justify-center font-display text-2xl font-bold text-text-marino/30 tracking-widest bg-bg-piedra w-full h-full select-none">
                {initials}
              </div>
            )}
          </div>
        </div>

        <!-- Información abreviada -->
        <div class="flex flex-col justify-between py-1">
          <div>
            <h2 class="font-display text-xl font-bold leading-tight mb-1">
              <a href={`/profesores/${prof.slug}`} class="text-text-marino hover:text-acento-verde no-underline transition-colors duration-150">
                {prof.fullName}
              </a>
            </h2>
            <p class="font-section text-[10px] uppercase tracking-wider font-semibold text-acento-verde mb-2">
              {prof.title}
            </p>
            <p class="text-xs text-text-marino/80 font-sans line-clamp-1 mb-3">
              {prof.department}
            </p>
            {prof.quote && (
              <p class="text-xs italic text-text-marino/60 font-sans border-l-2 border-acento-verde/45 pl-3 mb-4 line-clamp-2">
                “{prof.quote}”
              </p>
            )}
          </div>
          <div>
            <a href={`/profesores/${prof.slug}`} class="link-academic text-xs font-semibold">
              Ver perfil académico completo &rarr;
            </a>
          </div>
        </div>
      </div>
    );
  })}
</div>
