---
import InstitutionalLayout from '../layouts/InstitutionalLayout.astro';
import TeacherGrid from '../components/TeacherGrid.astro';
import { cargarProfesores } from '../lib/cargarProfesores.js';

const profesores = await cargarProfesores();
---

<InstitutionalLayout 
  title="Claustro Académico" 
  description="Registro formal y directorio de profesores investigadores. Consulta de trayectorias, producción científica y docencia."
>
  <div class="max-w-4xl mx-auto space-y-8">
    <div class="space-y-3">
      <h1 class="font-display text-4xl font-bold tracking-tight text-text-marino">
        Claustro Académico e Investigadores
      </h1>
      <p class="font-sans text-sm text-text-marino/70 max-w-2xl leading-relaxed">
        Presentación formal de la planta docente, adscripciones institucionales y áreas de especialización. Este registro recopila y comparte la producción científica, publicaciones y labor didáctica orientada a la comunidad estudiantil.
      </p>
    </div>

    <hr class="academic-divider-double" />

    <!-- Grid de Docentes -->
    <TeacherGrid profesores={profesores} />
  </div>
</InstitutionalLayout>
