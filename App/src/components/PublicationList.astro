---
interface Article {
  title: string;
  journal: string;
  year: number;
  impactFactor: number | null;
  doi: string | null;
}

interface Book {
  title: string;
  role: string;
  editorial: string;
  year: number;
}

interface Props {
  articles: Article[];
  books: Book[];
}

const { articles = [], books = [] } = Astro.props;

// Combinar artículos y libros en una sola lista cronológica para la vitrina y búsqueda
const allPubs = [
  ...articles.map(art => ({ ...art, type: 'article' as const })),
  ...books.map(bk => ({ ...bk, type: 'book' as const }))
].sort((a, b) => b.year - a.year);
---

<div class="space-y-6">
  
  <!-- Buscador e Interfaz de Filtros (Estándar Académico) -->
  <div class="bg-bg-piedra/30 border border-borde-gris p-4 rounded-sm">
    <input 
      type="text" 
      id="pub-search" 
      placeholder="Buscar publicación por título, revista, editorial o año..." 
      class="w-full border border-borde-gris px-3 py-2 text-xs bg-white text-text-marino rounded-sm font-sans mb-3 focus:outline-none focus:border-acento-verde/60"
    />
    <div class="flex flex-wrap items-center gap-2">
      <span class="text-[10px] uppercase font-sans tracking-wider font-bold text-text-marino/50 mr-1">Filtrar:</span>
      <button 
        class="filter-btn px-2.5 py-0.5 text-[9px] uppercase font-mono tracking-wider font-bold border border-acento-verde bg-acento-verde text-white rounded-xs cursor-pointer transition-all"
        data-filter="all"
      >
        Todos
      </button>
      <button 
        class="filter-btn px-2.5 py-0.5 text-[9px] uppercase font-mono tracking-wider font-bold border border-borde-gris bg-bg-piedra/40 text-text-marino/70 rounded-xs cursor-pointer hover:bg-acento-verde/25 hover:text-text-marino transition-all"
        data-filter="article"
      >
        Artículos
      </button>
      <button 
        class="filter-btn px-2.5 py-0.5 text-[9px] uppercase font-mono tracking-wider font-bold border border-borde-gris bg-bg-piedra/40 text-text-marino/70 rounded-xs cursor-pointer hover:bg-acento-verde/25 hover:text-text-marino transition-all"
        data-filter="book"
      >
        Libros
      </button>
    </div>
  </div>

  <!-- Contenedor Principal de Publicaciones -->
  <div id="publications-list" class="space-y-4">
    {allPubs.map(pub => (
      <div 
        class="pub-item border-l-4 border-l-acento-verde border-y border-r border-borde-gris/70 p-5 bg-white rounded-sm hover:shadow-xs hover:border-acento-verde/40 transition-all duration-200 flex gap-5"
        data-title={pub.title.toLowerCase()}
        data-type={pub.type}
        data-journal={pub.type === 'article' ? pub.journal.toLowerCase() : pub.editorial.toLowerCase()}
        data-year={pub.year.toString()}
      >
        <!-- Portada Vectorial 3:4 -->
        <div class="pub-cover w-20 h-28 shrink-0 select-none">
          <span class="text-[8px] uppercase tracking-wider text-acento-verde font-bold block">
            {pub.type === 'article' ? 'Artículo' : 'Libro'}
          </span>
          <span class="font-display text-3xl font-bold text-text-marino/20 block my-1">
            {pub.type === 'article' ? '†' : '■'}
          </span>
          <span class="font-mono text-xs font-bold text-text-marino/60 block">
            {pub.year}
          </span>
        </div>
        <!-- Contenido Ficha -->
        <div class="flex flex-col justify-between py-0.5 flex-1 min-w-0">
          <div>
            <h4 class="font-display text-base sm:text-lg font-bold text-text-marino leading-tight mb-2 tracking-tight">
              {pub.type === 'article' ? `“${pub.title}”` : pub.title}
            </h4>
            <p class="text-xs text-text-marino/80 font-sans leading-relaxed">
              {pub.type === 'article' ? (
                <span>Publicado en <span class="italic font-medium">{pub.journal}</span>.</span>
              ) : (
                <span>Libro por <span class="italic font-medium">{pub.editorial}</span>. Rol: {pub.role}.</span>
              )}
            </p>
          </div>
          <div class="mt-3 flex items-center justify-between text-xs font-mono">
            {pub.type === 'article' && pub.impactFactor && (
              <span class="badge-impact text-[10px] leading-none">FI {pub.impactFactor}</span>
            )}
            {pub.doi && (
              <a href={pub.doi} target="_blank" rel="noopener noreferrer" class="link-academic text-[10px]">
                → DOI / Enlace
              </a>
            )}
          </div>
        </div>
      </div>
    ))}

    <div 
      id="no-resultados" 
      class="hidden text-center py-8 text-xs italic text-text-marino/60 font-sans bg-white border border-borde-gris rounded-sm"
    >
      No se encontraron publicaciones que coincidan con los filtros.
    </div>
  </div>

</div>

<!-- Script de filtrado interactivo -->
<script>
  function initFilters() {
    const searchInput = document.getElementById('pub-search') as HTMLInputElement | null;
    const filterBtns = document.querySelectorAll('.filter-btn');
    const publicationsList = document.getElementById('publications-list');
    const noResultados = document.getElementById('no-resultados');

    if (!searchInput || !publicationsList) return;

    let activeFilter = 'all';

    function filterPublications() {
      const query = searchInput.value.toLowerCase().trim();
      const items = publicationsList.querySelectorAll('.pub-item');
      let matchesCount = 0;

      items.forEach((item: any) => {
        const title = item.getAttribute('data-title') || '';
        const journal = item.getAttribute('data-journal') || '';
        const year = item.getAttribute('data-year') || '';
        const type = item.getAttribute('data-type') || '';

        const matchesSearch = title.includes(query) || journal.includes(query) || year.includes(query);
        const matchesType = activeFilter === 'all' || type === activeFilter;

        if (matchesSearch && matchesType) {
          item.classList.remove('hidden');
          item.classList.add('flex');
          matchesCount++;
        } else {
          item.classList.remove('flex');
          item.classList.add('hidden');
        }
      });

      // Validar si hubo coincidencias
      if (matchesCount === 0) {
        noResultados?.classList.remove('hidden');
      } else {
        noResultados?.classList.add('hidden');
      }
    }

    searchInput.addEventListener('input', filterPublications);

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => {
          b.classList.remove('bg-acento-verde', 'text-white', 'border-acento-verde');
          b.classList.add('bg-bg-piedra/40', 'text-text-marino/70', 'border-borde-gris');
        });

        btn.classList.add('bg-acento-verde', 'text-white', 'border-acento-verde');
        btn.classList.remove('bg-bg-piedra/40', 'text-text-marino/70', 'border-borde-gris');

        activeFilter = btn.getAttribute('data-filter') || 'all';
        filterPublications();
      });
    });
  }

  // Ejecutar en carga de página y transiciones Astro
  initFilters();
  document.addEventListener('astro:page-load', initFilters);
</script>
