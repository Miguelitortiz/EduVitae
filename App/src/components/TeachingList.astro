---
interface Course {
  name: string;
  level: string;
  students: number;
  period: string;
}

interface Thesis {
  student: string;
  title: string;
  year: number;
  role: string;
}

interface Props {
  courses?: Course[];
  theses?: Thesis[];
  showOnly?: 'courses' | 'theses';
}

const { courses = [], theses = [], showOnly } = Astro.props;

// Extraer solo los 3 cursos principales
const visibleCourses = courses;

// Extraer máximo 2 tesis para la vista principal
const visibleTheses = theses;
const extraThesesCount = theses.length - 2;

// Función para abreviar nombres de materias y mantener los badges pequeños
function abbreviateCourse(name: string) {
  let short = name
    .replace(/Fundamentos de /gi, "Fund. ")
    .replace(/Programación /gi, "Prog. ")
    .replace(/ e /gi, " y ")
    .replace(/Orientada a Objetos/gi, "OO")
    .replace(/Inteligencia Artificial/gi, "IA")
    .replace(/Ciencia de Datos/gi, "CD");

  if (short.length > 25) {
    short = short.slice(0, 22) + "...";
  }
  return short;
}
---

<div class="space-y-8">
  <!-- Sección de Cursos Impartidos -->
  {(!showOnly || showOnly === 'courses') && (
    <div>
      <h3
        class="font-section text-xs uppercase tracking-widest font-semibold text-acento-verde mb-3.5 flex items-center"
      >
        <span class="text-acento-verde mr-2">§</span> Cursos Impartidos
      </h3>
      {
        visibleCourses.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {visibleCourses.map((course) => (
              <div class="border-l-3 border-l-acento-verde border-y border-r border-borde-gris/70 p-4 bg-bg-piedra/10 hover:bg-white rounded-sm hover:shadow-xs hover:border-acento-verde/40 transition-all duration-200 flex flex-col justify-between">
                <div>
                  <span class="text-[9px] uppercase tracking-widest font-mono text-acento-verde font-bold block mb-1">
                    {course.level}
                  </span>
                  <h4 class="font-section text-xs font-bold text-text-marino leading-snug">
                    {course.name}
                  </h4>
                </div>
                <div class="mt-3 flex items-end justify-between">
                  <div class="flex flex-col">
                    <span class="text-[8px] uppercase tracking-wider text-text-marino/50 font-bold font-sans">Periodo</span>
                    <span class="font-mono text-[9px] text-text-marino/75 font-semibold">{course.period}</span>
                  </div>
                  <div class="text-right">
                    <div class="flex items-baseline justify-end gap-1">
                      <span class="font-mono text-base font-bold text-acento-verde">{course.students}</span>
                      <span class="text-[8px] uppercase tracking-wider text-text-marino/60 font-semibold font-sans">Alumnos</span>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <p class="text-xs italic text-text-marino/60 font-sans">
            No se registran cursos impartidos recientemente.
          </p>
        )
      }
    </div>
  )}

  {!showOnly && courses.length > 0 && theses.length > 0 && (
    <hr class="academic-divider" />
  )}

  <!-- Sección de Tesis Dirigidas (Máx 2 items + ver más) -->
  {(!showOnly || showOnly === 'theses') && (
    <div>
      <h3
        class="font-section text-xs uppercase tracking-widest font-semibold text-acento-verde mb-3 flex items-center"
      >
        <span class="text-acento-verde mr-2">§</span> Tesis Asesoradas
      </h3>
      {
        visibleTheses.length > 0 ? (
          <div class="space-y-3">
            {visibleTheses.map((thesis) => (
              <div class="border-l-2 border-acento-verde bg-bg-piedra/15 p-3 rounded-sm flex flex-col justify-between text-xs">
                <div>
                  <h4 class="font-section text-xs font-semibold text-text-marino leading-snug italic">
                    “{thesis.title}”
                  </h4>
                </div>
                <div class="mt-2 flex flex-wrap justify-between items-center text-[10px] text-text-marino/80">
                  <div>
                    Tesista:{" "}
                    <span class="font-medium text-text-marino">
                      {thesis.student}
                    </span>
                  </div>
                  <div class="font-mono text-[9px] text-acento-verde font-semibold">
                    {thesis.role} &bull; {thesis.year}
                  </div>
                </div>
              </div>
            ))}

            {extraThesesCount > 0 && (
              <div class="pt-1 text-right">
                <button
                  data-open="modal-tesis"
                  class="link-academic font-section text-xs uppercase tracking-wider font-semibold cursor-pointer"
                >
                  +{extraThesesCount} tesis más →
                </button>
              </div>
            )}
          </div>
        ) : (
          <p class="text-xs italic text-text-marino/60 font-sans">
            No se registran tesis recientes.
          </p>
        )
      }
    </div>
  )}
</div>

<!-- ========================================== -->
<!-- MODALES DE REGISTRO COMPLETO (Vanilla JS) -->
<!-- ========================================== -->

<!-- Modal Tesis -->
{(!showOnly || showOnly === 'theses') && (
  <div
    id="modal-tesis"
    class="modal-overlay fixed inset-0 bg-text-marino/60 hidden items-center justify-center p-4 z-50 transition-opacity duration-150"
  >
    <div
      class="bg-white border-double-academic w-full max-w-2xl max-h-[80vh] flex flex-col rounded-sm shadow-xl overflow-hidden"
    >
      <!-- Encabezado Modal -->
      <div
        class="border-b border-borde-gris p-4 flex justify-between items-center bg-bg-piedra/60"
      >
        <span
          class="font-section text-xs uppercase tracking-wider font-semibold text-text-marino"
        >
          Registro Completo de Tesis Asesoradas y Dirigidas
        </span>
        <button
          class="close-modal font-mono text-xs font-bold border border-borde-gris px-2.5 py-0.5 bg-white hover:bg-acento-verde hover:text-white transition-colors duration-150 cursor-pointer"
        >
          X
        </button>
      </div>

      <!-- Contenido Scrollable -->
      <div class="p-6 overflow-y-auto scrollbar-academic flex-1 space-y-4">
        {
          theses.map((thesis) => (
            <div class="border-l-2 border-acento-verde bg-bg-piedra/20 p-4 rounded-sm flex flex-col justify-between text-xs">
              <div>
                <span class="text-[9px] uppercase font-mono tracking-widest text-text-marino/50 block mb-1">
                  Registro de Grado
                </span>
                <h4 class="font-section text-xs font-bold text-text-marino leading-snug italic">
                  “{thesis.title}”
                </h4>
              </div>
              <div class="mt-2.5 flex flex-wrap justify-between items-center text-[10px] text-text-marino/80 font-sans">
                <div>
                  Tesista: <span class="font-semibold">{thesis.student}</span>
                </div>
                <div class="font-mono text-[10px] text-acento-verde font-bold mt-1 sm:mt-0">
                  {thesis.role} &bull; {thesis.year}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
)}
